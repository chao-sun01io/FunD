# Production environment configuration for FunD
# Copy to backend/.env and fill in all values before deploying.

# === Django ===
# REQUIRED: generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# or use `openssl rand -base64 50` in terminal to generate a strong random string
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# === Domain (used by nginx template) ===
DOMAIN=yourdomain.com

# === PostgreSQL ===
USE_POSTGRES=True
POSTGRES_DB=fund_prod
POSTGRES_USER=fund_user
# REQUIRED: use a strong random password
POSTGRES_PASSWORD=
POSTGRES_DB_HOST=db
POSTGRES_DB_PORT=5432

# === Redis (internal Docker network, use native port 6379) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_CELERY_BROKER=0
REDIS_DB_INFO_APP_STORAGE=1
CELERY_BROKER_URL=redis://redis:6379/0

# === Logging ===
LOG_LEVEL=WARNING
