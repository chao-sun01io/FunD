# Local hybrid dev environment.
# Used when running Django/Celery as local processes against Docker infrastructure.
#
# Setup:
#   1. cp backend/.env.local.example backend/.env
#   2. Fill in DJANGO_SECRET_KEY and POSTGRES_PASSWORD
#   3. docker-compose -f docker-compose.infra.yml up -d
#   4. cd backend && python manage.py migrate
#   5. python manage.py runserver

# Redis — mapped to localhost via docker-compose.infra.yml
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB_CELERY_BROKER=0
REDIS_DB_INFO_APP_STORAGE=1

CELERY_BROKER_URL=redis://localhost:6380/0

DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# Set to True to use PostgreSQL (requires docker-compose.infra.yml running).
# Set to False (or omit) to use SQLite — no Docker needed for unit tests.
USE_POSTGRES=True

# PostgreSQL — mapped to localhost via docker-compose.infra.yml
POSTGRES_DB=my_fund_db
POSTGRES_USER=my_fund_user
POSTGRES_PASSWORD=a_very_strong_password
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
