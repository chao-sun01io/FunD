REDIS_HOST=redis
REDIS_PORT=6380
REDIS_DB_CELERY_BROKER=0
REDIS_DB_INFO_APP_STORAGE=1

CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB_CELERY_BROKER}
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# Set to True when using Docker (docker-compose sets up PostgreSQL).
# Leave False (or unset) for local development with SQLite.
USE_POSTGRES=False

# PostgreSQL Settings
POSTGRES_DB=my_fund_db
POSTGRES_USER=my_fund_user
# Warning! Make sure to replace & use a strong password in production
POSTGRES_PASSWORD=a_very_strong_password
# This MUST match the service name in docker-compose.yml
POSTGRES_DB_HOST=db
POSTGRES_DB_PORT=5432